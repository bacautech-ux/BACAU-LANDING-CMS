{
  "name": "bacau-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' node node_modules/next/dist/bin/next dev",
    "generate:importmap": "PAYLOAD_CONFIG_PATH=payload.config.ts node_modules/.bin/payload generate:importMap",
    "migrate": "PAYLOAD_CONFIG_PATH=payload.config.ts node_modules/.bin/payload migrate",
    "migrate:create": "PAYLOAD_CONFIG_PATH=payload.config.ts node_modules/.bin/payload migrate:create",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "seed": "PAYLOAD_CONFIG_PATH=payload.config.ts node_modules/.bin/payload run src/seed.ts",
    "migrate:home-page": "NODE_ENV=development PAYLOAD_CONFIG_PATH=payload.config.ts node_modules/.bin/payload run src/scripts/runMigrateHomeGlobalToPage.ts",
    "lint": "node node_modules/eslint/bin/eslint.js"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.0",
    "@payloadcms/next": "^3.84.0",
    "@payloadcms/plugin-cloud-storage": "^3.84.0",
    "@payloadcms/richtext-lexical": "^3.84.0",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "payload": "^3.84.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sass": "^1.99.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
